    "# 1️⃣ Ensure datetime index FIRST\n",
    "df.index = pd.to_datetime(df.index)\n",
    "\n",
    "\n",
    "y = df['energy_kwh']\n",
    "\n",
    "# ===============================\n",
    "# 2. Train/Test Split\n",
    "# ===============================\n",
    "split_date = '2023-01-01'\n",
    "y_train = y[y.index < split_date]\n",
    "y_test = y[y.index >= split_date]\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 58,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fit ARIMA\n",
    "arima_model = ARIMA(y_train, order=(5,1,0))  # adjust p,d,q\n",
    "arima_fit = arima_model.fit()\n",
    "arima_pred = arima_fit.forecast(steps=len(y_test))\n",
    "\n",
    "# Evaluation\n",
    "arima_mae = mean_absolute_error(y_test, arima_pred)\n",
    "arima_rmse = np.sqrt(mean_squared_error(y_test, arima_pred))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "\n",
    "\n",
    "# last 90 days only\n",
    "y_train_short = y_train.last('90D')\n",
    "\n",
    "sarima_model = SARIMAX(\n",
    "    y_train_short,\n",
    "    order=(1,1,1),\n",
    "    seasonal_order=(1,0,1,24),\n",
    "    enforce_stationarity=False,\n",
    "    enforce_invertibility=False)\n",
    "\n",
    "sarima_fit = sarima_model.fit(disp=False)\n",
    "sarima_pred = sarima_fit.forecast(steps=len(y_test))\n",
    "\n",
    "# Evaluation\n",
    "sarima_mae = mean_absolute_error(y_test, sarima_pred)\n",
    "sarima_rmse = np.sqrt(mean_squared_error(y_test, sarima_pred))"
   ]
