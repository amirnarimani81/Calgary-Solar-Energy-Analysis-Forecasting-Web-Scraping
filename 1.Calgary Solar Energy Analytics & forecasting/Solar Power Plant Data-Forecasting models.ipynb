    "# MSE, RMSE, MAPE\n",
    "mse = mean_squared_error(y_true, y_pred)\n",
    "rmse = np.sqrt(mse)\n",
    "mape = np.mean(np.abs((y_true - y_pred)/y_true)) * 100\n",
    "\n",
